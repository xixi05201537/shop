generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Admin {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Product {
  id                      String   @id @default(cuid())
  name                    String
  imageUrl                String?  @db.VarChar(2048)
  imageSource             String   @default("url")
  uploadedImagePath       String?  @db.VarChar(2048)
  shortDescription        String
  longDescriptionMarkdown String   @db.LongText
  enabledAmounts          String   @default("[0.1,1,10,30,50]")
  defaultAmount           Float    @default(1)
  defaultQuantity         Int      @default(1)
  maxQuantity             Int      @default(99)
  isActive                Boolean  @default(true)
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
}

model SelectionPage {
  id             String                @id @default(cuid())
  title          String
  slug           String                @unique
  description    String?               @db.LongText
  submitLabel    String                @default("提交选择")
  isPublished    Boolean               @default(true)
  showPrices     Boolean               @default(true)
  allowQuantity  Boolean               @default(true)
  showName        Boolean               @default(true)
  showEmail       Boolean               @default(true)
  showContact     Boolean               @default(true)
  requireName    Boolean               @default(false)
  requireEmail   Boolean               @default(false)
  requireContact Boolean               @default(false)
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt
  items          SelectionItem[]
  submissions    SelectionSubmission[]
}

model SelectionItem {
  id          String          @id @default(cuid())
  pageId      String
  page        SelectionPage   @relation(fields: [pageId], references: [id], onDelete: Cascade)
  title       String
  imageUrl    String          @db.VarChar(2048)
  description String?         @db.LongText
  price       Float?
  currency    String          @default("USD")
  sortOrder   Int             @default(0)
  minQuantity Int             @default(1)
  maxQuantity Int             @default(99)
  isActive    Boolean         @default(true)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  submissions SelectionSubmissionItem[]

  @@index([pageId, sortOrder])
}

model SelectionSubmission {
  id            String                    @id @default(cuid())
  pageId        String
  page          SelectionPage             @relation(fields: [pageId], references: [id], onDelete: Cascade)
  customerName  String?
  customerEmail String?
  customerContact String?
  note          String?                   @db.LongText
  status        String                    @default("pending")
  totalQuantity Int
  totalAmount   Float?
  createdAt     DateTime                  @default(now())
  updatedAt     DateTime                  @updatedAt
  items         SelectionSubmissionItem[]
  checkouts     SelectionCheckoutSubmission[]

  @@index([pageId, createdAt])
  @@index([status])
}

model SelectionSubmissionItem {
  id                  String              @id @default(cuid())
  submissionId        String
  submission          SelectionSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  itemId              String?
  item                SelectionItem?      @relation(fields: [itemId], references: [id], onDelete: SetNull)
  titleSnapshot       String
  imageSnapshot       String              @db.VarChar(2048)
  descriptionSnapshot String?             @db.LongText
  priceSnapshot       Float?
  currencySnapshot    String              @default("USD")
  quantity            Int
  lineTotal           Float?

  @@index([submissionId])
  @@index([itemId])
}

model SelectionCheckout {
  id              String                        @id @default(cuid())
  token           String                        @unique
  status          String                        @default("pending")
  customerName    String?
  customerEmail   String?
  customerContact String?
  totalQuantity   Int
  subtotalAmount   Float                         @default(0)
  totalAmount     Float
  currency        String                        @default("USD")
  emailRecipient   String?
  emailStatus      String                        @default("pending")
  emailError       String?                       @db.LongText
  emailedAt        DateTime?
  paypalOrderId   String?                       @unique
  paypalCaptureId String?
  paypalRawSummary String?                      @db.LongText
  paidAt          DateTime?
  createdAt       DateTime                      @default(now())
  updatedAt       DateTime                      @updatedAt
  submissions     SelectionCheckoutSubmission[]

  @@index([status])
  @@index([createdAt])
}

model SelectionCheckoutSubmission {
  id           String              @id @default(cuid())
  checkoutId   String
  checkout     SelectionCheckout   @relation(fields: [checkoutId], references: [id], onDelete: Cascade)
  submissionId String
  submission   SelectionSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@unique([checkoutId, submissionId])
  @@index([submissionId])
}

model PaymentRequest {
  id               String                @id @default(cuid())
  token            String                @unique
  title            String
  description      String                @db.LongText
  totalAmount      Float
  currency         String                @default("USD")
  status           String                @default("pending")
  adminNote        String?               @db.LongText
  emailRecipient   String?
  emailStatus      String                @default("pending")
  emailError       String?               @db.LongText
  emailedAt        DateTime?
  paidEmailStatus  String                @default("pending")
  paidEmailError   String?               @db.LongText
  paidEmailedAt    DateTime?
  paypalOrderId    String?               @unique
  paypalCaptureId  String?
  paypalRawSummary String?               @db.LongText
  paidAt           DateTime?
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
  images           PaymentRequestImage[]

  @@index([status])
  @@index([createdAt])
}

model PaymentRequestImage {
  id               String         @id @default(cuid())
  paymentRequestId String
  paymentRequest   PaymentRequest @relation(fields: [paymentRequestId], references: [id], onDelete: Cascade)
  imageUrl         String         @db.VarChar(2048)
  caption          String?        @db.VarChar(255)
  price            Float          @default(0)
  sortOrder        Int            @default(0)

  @@index([paymentRequestId, sortOrder])
}

model Article {
  id        String   @id @default(cuid())
  slug      String   @unique
  title     String
  content   String   @db.LongText
  published Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SiteConfig {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String   @db.LongText
  secret    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Order {
  id                  String    @id @default(cuid())
  orderNumber         String    @unique
  paypalOrderId       String?   @unique
  paypalCaptureId     String?
  productNameSnapshot String
  productImageSnapshot String?   @db.VarChar(2048)
  buyerEmail          String?
  buyerNickname       String?
  paypalBuyerEmail    String?
  paypalBuyerNickname String?
  paypalPayerId       String?
  paypalShippingName  String?
  paypalShippingAddress String?  @db.LongText
  unitAmount          Float
  quantity            Int
  totalAmount         Float
  currency            String    @default("USD")
  status              String    @default("created")
  paypalRawSummary    String?   @db.LongText
  buyerEmailStatus    String    @default("pending")
  buyerEmailError     String?   @db.LongText
  adminEmailStatus    String    @default("pending")
  adminEmailError     String?   @db.LongText
  trackingNumber      String?
  shippedAt           DateTime?
  shipmentEmailStatus String    @default("pending")
  shipmentEmailError  String?   @db.LongText
  internalNote        String?   @db.LongText
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  paidAt              DateTime?
}

model PayerNote {
  id        String   @id @default(cuid())
  payerId   String   @unique
  note      String   @db.LongText
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model WebhookEvent {
  id            String   @id @default(cuid())
  paypalEventId String   @unique
  eventType     String
  resourceId    String?
  payload       String   @db.LongText
  processed     Boolean  @default(false)
  createdAt     DateTime @default(now())
}

model AuditLog {
  id         String   @id @default(cuid())
  adminId    String?
  action     String
  targetType String
  targetId   String?
  summary    String   @db.VarChar(512)
  metadata   String?  @db.LongText
  createdAt  DateTime @default(now())

  @@index([createdAt])
  @@index([targetType, targetId])
}
